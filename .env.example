# Portfolio demo — synthetic data only (no Snowflake credentials required)
DATA_SOURCE=mock

# Snowflake (ignored when DATA_SOURCE=mock)
SNOWFLAKE_ACCOUNT=demo.analytics.local
SNOWFLAKE_USER=demo@example.com
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=SANDBOX_WH
SNOWFLAKE_DATABASE=ANALYTICS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_ROLE=READER
SNOWFLAKE_AUTHENTICATOR=externalbrowser

LITELLM_MODEL=gpt-5
LITELLM_API_KEY=

DEFAULT_CITY=Ridgeport
CACHE_TTL_SECONDS=300

VENUE_LATE_THRESHOLD=300
VENUE_EARLY_THRESHOLD=-300
COURIER_WAIT_THRESHOLD=300
SLOW_PICKUP_BUFFER_MIN=10
UNDERSUPPLY_THRESHOLD_MIN=10
ROTTEN_THRESHOLD_MIN=20
